# i3 config file (v4)
#
# Please see https://i3wm.org/docs/userguide.html for a complete reference!
set $mod Mod4

# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
# font pango:UbuntuMono Nerd Font Mono 11 
font pango:DejaVuSansM Nerd Font 8 

exec --no-startup-id xrandr --auto --output DP-2 --mode 1920x1080 --right-of DP-0
exec --no-startup-id dex-autostart --autostart --environment i3
exec --no-startup-id xss-lock --transfer-sleep-lock -- ~/Dev/bash/lock --nofork
exec --no-startup-id /usr/libexec/xfce4/notifyd/xfce4-notifyd &
exec --no-startup-id ~/.fehbg &
exec --no-startup-id python ~/Dev/py/scripts/i3-orientation.py &
exec --no-startup-id python ~/Dev/py/scripts/i3-swallow.py &
exec --no-startup-id ~/Dev/bash/weather &
exec --no-startup-id ~/Dev/bash/radio &
exec --no-startup-id ~/Dev/bash/pidswallow --loop &
exec --no-startup-id kitty -e pacmixer &
exec --no-startup-id kitty sh -c "pyradio --log-titles" &
exec --no-startup-id kitty --title "floatterm" &
exec --no-startup-id xfce4-power-manager &
exec --no-startup-id setxkbmap -layout de,gr -option caps:escape
exec --no-startup-id udiskie -t &
exec --no-startup-id nm-applet & 
exec --no-startup-id picom -b
exec --no-startup-id blueman-applet &
exec --no-startup-id thunderbird
exec --no-startup-id flatpak run com.spotify.Client

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# App stuff
bindsym $mod+m [class="Spotify"] scratchpad show
bindsym $mod+t [class="thunderbird"] scratchpad show
bindsym $mod+p [title="PyRadio*"] scratchpad show
bindsym $mod+q [title="pacmixer*"] scratchpad show
bindsym $mod+y [title="floatterm*"] scratchpad show
bindsym Print exec flameshot gui

# kill focused window
bindsym $mod+Shift+q kill

# browser and terminal spawn
bindsym $mod+Shift+Return exec --no-startup-id kitty
bindsym $mod+b exec --no-startup-id firefox 

# start dmenu (a program launcher)
bindsym $mod+d exec --no-startup-id "dmenu_run -h 20 -i -b -p 'DMenu:'"
bindsym $mod+Shift+e exec --no-startup-id "~/Dev/bash/dmenu-shutdown"

# special keys
bindsym $mod+Tab exec --no-startup-id ~/Dev/bash/setkb && killall -USR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id ~/Dev/bash/incvol && killall -USR1 i3status
bindsym XF86AudioLowerVolume exec --no-startup-id ~/Dev/bash/decvol && killall -USR1 i3status
bindsym XF86AudioMute exec --no-startup-id ~/Dev/bash/mute && killall -USR1 i3status

# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# split in horizontal orientation
bindsym $mod+c split toggle

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# focus the parent container
bindsym $mod+a focus parent

# Define names for default workspaces for which we configure key bindings later on.
# We use variables to avoid repeating the names in multiple places.
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# reload the configuration file
bindsym $mod+Shift+c reload
# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+r restart

# move workspaces to other output
bindsym $mod+Left move workspace to output left
bindsym $mod+Right move workspace to output right

# resize window (you can also use the mouse for that)
bindsym $mod+r mode "resize mode"
mode "resize mode" {
        # These bindings trigger as soon as you enter the resize mode
       bindsym h resize shrink width 5 px or 5 ppt
        bindsym k resize grow height 5 px or 5 ppt
        bindsym j resize shrink height 5 px or 5 ppt
        bindsym l resize grow width 5 px or 5 ppt

        # back to normal: Enter or Escape or $mod+r
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}

bindsym $mod+g mode "edit gaps"
mode "edit gaps" {
        bindsym plus gaps inner current plus 5
        bindsym k  gaps inner current plus 5
        bindsym l  gaps inner current plus 5
        bindsym minus gaps inner current minus 5
        bindsym j gaps inner current minus 5
        bindsym h gaps inner current minus 5
        bindsym 0 gaps inner current set 0
        bindsym Shift+plus gaps inner all plus 5
        bindsym Shift+k gaps inner all plus 5
        bindsym Shift+l gaps inner all plus 5
        bindsym Shift+minus gaps inner all minus 5
        bindsym Shift+j gaps inner all minus 5
        bindsym Shift+h gaps inner all minus 5
        bindsym Shift+0 gaps inner all set 0
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+g mode "default"
}

bindsym $mod+Return mark --add "swapee"; mode "swap window"
mode "swap window" {
	bindsym $mod+1 workspace $ws1
	bindsym $mod+2 workspace $ws2
	bindsym $mod+3 workspace $ws3
	bindsym $mod+4 workspace $ws4
	bindsym $mod+5 workspace $ws5
	bindsym $mod+6 workspace $ws6
	bindsym $mod+7 workspace $ws7
	bindsym $mod+8 workspace $ws8
	bindsym $mod+9 workspace $ws9
	bindsym $mod+0 workspace $ws10
	bindsym h focus left
	bindsym j focus down
	bindsym k focus up
	bindsym l focus right
	bindsym Return swap container with mark "swapee"; unmark "swapee"; mode "default";
	bindsym Escape unmark "swapee"; mode "default";
}

# class                 border  bground text    indicator child_border
client.focused          #8C8C8C #005577 #FFFFFF #005577   #005577
client.focused_inactive #8C8C8C #4C4C4C #FFFFFF #4C4C4C   #222222 
client.unfocused        #4C4C4C #222222 #888888 #292D2E   #222222
client.urgent           #EC69A0 #DB3279 #FFFFFF #DB3279   #DB3279
client.placeholder      #000000 #0C0C0C #FFFFFF #000000   #0C0C0C
client.background       #FFFFFF

gaps inner 25
smart_gaps on
smart_borders on
focus_follows_mouse no
for_window [window_role="pop-up"] floating enable
for_window [window_role="task_dialog"] floating enable
for_window [title="Preferences$"] floating enable
for_window [class="Skype"] floating enable
for_window [class="steam"] floating enable
for_window [class="krita"] floating enable
for_window [class="Gimp*"] floating enable
for_window [class="libreoffice-*"] floating enable
for_window [class="Blueman-manager"] floating enable
for_window [class="Pavucontrol"] floating enable
for_window [class="Audacity"] floating enable
for_window [class="Steam"] floating enable
default_border pixel 1
default_floating_border normal
for_window [class="Spotify"] move scratchpad 
for_window [class="thunderbird"] move scratchpad
for_window [title="PyRadio*"] move scratchpad
for_window [title="pacmixer*"] move scratchpad
for_window [title="floatterm*"] move scratchpad

# Start i3bar to display a workspace bar (plus the system information i3status
# finds out, if available)
bar {
    font pango:DejaVuSansM Nerd Font 8 
    separator_symbol "   "
    tray_output primary 
    colors {
        background #222222
        statusline #888888
        separator  #444444

        focused_workspace  #8C8C8C #005577 #FFFFFF
        active_workspace   #3C6EB4 #294172 #FFFFFF
        inactive_workspace #8C8C8C #222222 #888888
        urgent_workspace   #EC69A0 #DB3279 #FFFFFF
        binding_mode       #8C8C8C #A3c060 #222222
    }
    status_command i3status | ~/Src/i3spotifystatus/pystatus.py 
}
