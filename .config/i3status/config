# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
        output_format = "i3bar"
        markup = "pango"
        colors = false
        interval = 5
}

#order += "cpu_usage"
#order += "memory"
#order += "disk /"
order += "read_file radio"
#order += "ethernet eno1"
#order += "wireless wlo1"
order += "read_file weather"
order += "tztime date"
order += "read_file vol"
order += "read_file xkb"
order += "battery 0" 
order += "tztime clock"

cpu_usage {
    format = "󰻠 %usage"
}
memory {
        format = "󰍛 %used"
}
wireless wlo1 {
    format_up = "󰩠 %ip"
    format_down = ""
}
ethernet eno1 {
    format_up = "󰩠 %ip"
    format_down = ""
}
disk "/" {
   format = "󰋊 %free"
}
tztime clock {
        format = "<span color='#83cafa'>%time</span>"
        format_time = "%H:%M "
}
tztime date {
        format = " %d.%m"
}     
read_file xkb {
    format_bad = "<span color='#83cafa'> gr</span>"
    path = "/home/oli/Dev/bash/xkb"
}
read_file vol {
    format_bad = "<span color='#83cafa'>󰎄 --</span>"
    path = "/home/oli/Dev/bash/vol"
}
read_file weather {
    path = "/home/oli/Src/ansiweather/weather"
}
read_file radio {
    format = "<span color='#9ec600'>%content</span>"
    path = "/home/oli/Dev/bash/station"
}
battery 0 {
    format = "%status%percentage"
    status_chr = " "
    status_bat = "󱟤 "
    status_unk = " "
    status_full = "󱟢"
	integer_battery_capacity = true
}
