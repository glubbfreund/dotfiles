[submodule ".config/nvim"]
	path = .config/nvim
	url = https://github.com/glubbfreund/nvim-config
[submodule "Dev/bash"]
	path = Dev/bash
	url = https://github.com/glubbfreund/bash-scripts
[submodule "Src/i3-master-layout"]
